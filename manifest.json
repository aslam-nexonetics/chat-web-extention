{
  "manifest_version": 3,
  "name": "Nexonetics Chat Extension",
  "version": "1.0.0",
  "description": "Floating chat window for Nexonetics Chat App.",
  "icons": {
    "16": "assets/icons/icon.png",
    "32": "assets/icons/icon.png",
    "48": "assets/icons/icon.png",
    "128": "assets/icons/icon.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["auth.js", "chat.js", "content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/icons/icon.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
